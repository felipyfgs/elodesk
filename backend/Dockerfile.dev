FROM golang:1.25-alpine

RUN apk add --no-cache git curl

# Install Air for hot-reload
RUN go install github.com/air-verse/air@latest

WORKDIR /app

# Pre-download deps (cached layer)
COPY go.mod go.sum ./
RUN go mod download

# Source is mounted as volume at runtime
EXPOSE 3001

CMD ["air", "-c", ".air.toml"]
