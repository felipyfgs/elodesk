# Server
PORT=3001
SERVER_HOST=0.0.0.0
GO_ENV=development
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://wzap:wzap@localhost:5432/wzap?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me-to-at-least-32-characters-long-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Key Encryption Key (base64-encoded 32 bytes)
# Generate with: openssl rand -base64 32
BACKEND_KEK=change-me-base64-encoded-32-bytes-key

# MinIO — DEFAULTS for local dev only; ALWAYS change for staging/production
MINIO_ENDPOINT=localhost
MINIO_PORT=9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=backend-media

# Public URL
API_URL=http://localhost:3001

# CORS (comma-separated origins, * for all)
CORS_ORIGINS=*

# Meta (Instagram + Facebook) channels
META_APP_ID=
META_APP_SECRET=
META_GRAPH_VERSION=v22.0
INSTAGRAM_VERIFY_TOKEN=
FB_VERIFY_TOKEN=
# Set to true in development to skip webhook signature verification
META_ALLOW_UNSIGNED=false

# Channel feature flags (default: tiktok=false, twitter=false, twilio_whatsapp=true, twilio_sms=false)
FEATURE_CHANNEL_TIKTOK=false
FEATURE_CHANNEL_TWITTER=false
FEATURE_CHANNEL_TWILIO_WHATSAPP=true
FEATURE_TWILIO_SMS_MEDIUM=false

# TikTok OAuth (required when FEATURE_CHANNEL_TIKTOK=true)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Twitter OAuth (required when FEATURE_CHANNEL_TWITTER=true)
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
